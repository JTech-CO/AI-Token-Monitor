{
  "name": "ai-token-monitor",
  "version": "1.0.0",
  "description": "Claude Code / Codex CLI 토큰 사용량과 비용을 실시간으로 보여주는 데스크톱 오버레이",
  "author": "JTech-CO",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JTech-CO/AI-Token-Monitor.git"
  },
  "homepage": "https://github.com/JTech-CO/AI-Token-Monitor",
  "bugs": {
    "url": "https://github.com/JTech-CO/AI-Token-Monitor/issues"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.jtech.ai-token-monitor",
    "productName": "AI Token Monitor",
    "directories": { "output": "dist" },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
